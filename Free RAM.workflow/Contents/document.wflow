				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run AppleScript.action</string>
				<key>ActionName</key>
				<string>Esegui AppleScript</string>
				<key>ActionParameters</key>
				<dict>
					<key>source</key>
					<string>on run {input, parameters}    try        do shell script "purge" with administrator privileges        display notification "RAM successfully purged." with title "System Maintenance"    on error        display notification "Purge cancelled or failed." with title "System Maintenance"    end try    return inputend run</string>
