				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run Shell Script.action</string>
				<key>ActionName</key>
				<string>Esegui script shell</string>
				<key>ActionParameters</key>
				<dict>
					<key>COMMAND_STRING</key>
					<string># Run the test and pipe the output to awk for formatting
networkQuality | awk '
/Downlink capacity/ { down = $3; d_unit = $4 }
/Uplink capacity/ { up = $3; u_unit = $4 }
/Idle Latency/ { ping = $3 }
END {
    print "Download Speed: " down " " d_unit
    print "Upload Speed: " up " " u_unit
    print "Ping: " ping " ms"
}'</string>
					<key>CheckedForUserDefaultShell</key>
					<true/>
					<key>inputMethod</key>
					<integer>0</integer>
					<key>shell</key>
					<string>/bin/bash</string>
					<key>source</key>
					<string></string>
				</dict>
